#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

BACKEND_PID_FILE="$SCRIPT_DIR/backend.pid"
FRONTEND_PID_FILE="$SCRIPT_DIR/frontend.pid"

is_running() {
  local pid="$1"
  kill -0 "$pid" >/dev/null 2>&1
}

port_pids() {
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -t -iTCP:"$port" -sTCP:LISTEN 2>/dev/null | sort -u
    return 0
  fi

  if command -v ss >/dev/null 2>&1; then
    ss -ltnp 2>/dev/null | awk -v p=":${port}" '
      $4 ~ p"$" {
        if (match($0, /pid=[0-9]+/)) {
          print substr($0, RSTART + 4, RLENGTH - 4)
        }
      }
    ' | sort -u
    return 0
  fi

  return 1
}

kill_pids() {
  local pids="$1"
  if [[ -z "${pids// }" ]]; then
    return 0
  fi

  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    kill "$pid" >/dev/null 2>&1 || true
  done <<<"$pids"

  sleep 1

  while IFS= read -r pid; do
    [[ -z "$pid" ]] && continue
    if is_running "$pid"; then
      kill -9 "$pid" >/dev/null 2>&1 || true
    fi
  done <<<"$pids"
}

stop_by_port() {
  local name="$1"
  local port="$2"

  local pids
  pids="$(port_pids "$port" || true)"
  if [[ -z "${pids// }" ]]; then
    return 0
  fi

  echo "found unmanaged $name process on port $port, stopping..."
  kill_pids "$pids"
}

stop_one() {
  local name="$1"
  local pid_file="$2"

  if [[ ! -f "$pid_file" ]]; then
    echo "$name is not running (no pid file)."
    return 0
  fi

  local pid
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  if [[ -z "$pid" ]]; then
    rm -f "$pid_file"
    echo "$name pid file is empty, cleaned."
    return 0
  fi

  if ! is_running "$pid"; then
    rm -f "$pid_file"
    echo "$name process not found, stale pid cleaned ($pid)."
    return 0
  fi

  echo "stopping $name (pid: $pid)..."
  kill "$pid" >/dev/null 2>&1 || true

  for _ in {1..10}; do
    if ! is_running "$pid"; then
      break
    fi
    sleep 1
  done

  if is_running "$pid"; then
    echo "$name did not exit in time, sending SIGKILL..."
    kill -9 "$pid" >/dev/null 2>&1 || true
  fi

  rm -f "$pid_file"
  echo "$name stopped."
}

echo "==== SeeDance stop ===="
stop_one "frontend" "$FRONTEND_PID_FILE"
stop_one "backend" "$BACKEND_PID_FILE"
stop_by_port "frontend" 5173
stop_by_port "backend" 8000
echo "all stop commands executed."
