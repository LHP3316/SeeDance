#!/bin/bash
# SeeDance 一键启动脚本

set -e

# 获取脚本所在目录
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR"

echo "========================================="
echo "  SeeDance 一键启动"
echo "========================================="
echo ""

# 检查后端是否已在运行
if [ -f "backend.pid" ]; then
    PID=$(cat backend.pid)
    if kill -0 $PID 2>/dev/null; then
        echo "⚠️  后端服务已在运行 (PID: $PID)"
        echo "如需重启，请先执行: ./stop"
        exit 1
    else
        echo "清理过期的PID文件..."
        rm -f backend.pid
    fi
fi

# 检查前端是否已在运行
if [ -f "frontend.pid" ]; then
    PID=$(cat frontend.pid)
    if kill -0 $PID 2>/dev/null; then
        echo "⚠️  前端服务已在运行 (PID: $PID)"
        echo "如需重启，请先执行: ./stop"
        exit 1
    else
        echo "清理过期的PID文件..."
        rm -f frontend.pid
    fi
fi

# 启动后端
echo "启动后端服务..."
cd backend
nohup bash start.sh >> "${SCRIPT_DIR}/logs/backend.log" 2>&1 &
BACKEND_PID=$!
echo $BACKEND_PID > "${SCRIPT_DIR}/backend.pid"
cd ..
echo "✓ 后端已启动 (PID: $BACKEND_PID)"

# 等待后端启动
sleep 2

# 启动前端
echo ""
echo "启动前端服务..."
cd frontend
nohup npm run dev >> "${SCRIPT_DIR}/logs/frontend.log" 2>&1 &
FRONTEND_PID=$!
echo $FRONTEND_PID > "${SCRIPT_DIR}/frontend.pid"
cd ..
echo "✓ 前端已启动 (PID: $FRONTEND_PID)"

echo ""
echo "========================================="
echo "  启动完成！"
echo "========================================="
echo ""
echo "后端服务: http://localhost:8000"
echo "API文档:  http://localhost:8000/docs"
echo "前端服务: http://localhost:5173"
echo ""
echo "查看日志: tail -f ${SCRIPT_DIR}/logs/backend.log"
echo "          tail -f ${SCRIPT_DIR}/logs/frontend.log"
echo ""
echo "停止服务: ./stop"
echo "查看状态: ./status"
echo "重启服务: ./restart"
echo ""
