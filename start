#!/usr/bin/env bash
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

BACKEND_PID_FILE="$SCRIPT_DIR/backend.pid"
FRONTEND_PID_FILE="$SCRIPT_DIR/frontend.pid"
BACKEND_LOG="$SCRIPT_DIR/logs/backend.log"
FRONTEND_LOG="$SCRIPT_DIR/logs/frontend.log"

mkdir -p "$SCRIPT_DIR/logs"

is_running() {
  local pid="$1"
  kill -0 "$pid" >/dev/null 2>&1
}

cleanup_stale_pid() {
  local pid_file="$1"
  if [[ -f "$pid_file" ]]; then
    local pid
    pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && is_running "$pid"; then
      return 0
    fi
    rm -f "$pid_file"
  fi
  return 1
}

start_backend() {
  if cleanup_stale_pid "$BACKEND_PID_FILE"; then
    echo "backend is already running (pid: $(cat "$BACKEND_PID_FILE"))"
    return 1
  fi

  if [[ -s "$SCRIPT_DIR/backend/start.sh" ]]; then
    (
      cd "$SCRIPT_DIR/backend"
      nohup bash ./start.sh >>"$BACKEND_LOG" 2>&1 &
      echo $! >"$BACKEND_PID_FILE"
    )
  elif [[ -s "$SCRIPT_DIR/backend/main.py" ]]; then
    (
      cd "$SCRIPT_DIR/backend"
      nohup python3 -m uvicorn main:app --host 0.0.0.0 --port 8000 >>"$BACKEND_LOG" 2>&1 &
      echo $! >"$BACKEND_PID_FILE"
    )
  else
    echo "backend entrypoint not found: backend/start.sh and backend/main.py are unavailable."
    return 1
  fi

  local pid
  pid="$(cat "$BACKEND_PID_FILE")"
  sleep 2
  if ! is_running "$pid"; then
    echo "failed to start backend, check logs: $BACKEND_LOG"
    rm -f "$BACKEND_PID_FILE"
    return 1
  fi
  echo "backend started (pid: $pid)"
}

start_frontend() {
  if cleanup_stale_pid "$FRONTEND_PID_FILE"; then
    echo "frontend is already running (pid: $(cat "$FRONTEND_PID_FILE"))"
    return 1
  fi

  if [[ ! -s "$SCRIPT_DIR/frontend/package.json" ]]; then
    echo "frontend entrypoint not found: frontend/package.json is missing or empty."
    return 1
  fi

  (
    cd "$SCRIPT_DIR/frontend"
    nohup npm run dev >>"$FRONTEND_LOG" 2>&1 &
    echo $! >"$FRONTEND_PID_FILE"
  )

  local pid
  pid="$(cat "$FRONTEND_PID_FILE")"
  sleep 2
  if ! is_running "$pid"; then
    echo "failed to start frontend, check logs: $FRONTEND_LOG"
    rm -f "$FRONTEND_PID_FILE"
    return 1
  fi
  echo "frontend started (pid: $pid)"
}

echo "==== SeeDance start ===="
start_backend
start_frontend
echo "all start commands executed."
echo "use ./status to check runtime status."
