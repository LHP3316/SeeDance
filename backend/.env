# 数据库配置
DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/seedance_backend

# JWT配置
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600

# 应用配置
APP_NAME=SeeDance后台管理系统
APP_VERSION=1.0.0
DEBUG=True
