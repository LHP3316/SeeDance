#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

BACKEND_PID_FILE="$SCRIPT_DIR/backend.pid"
FRONTEND_PID_FILE="$SCRIPT_DIR/frontend.pid"

is_running() {
  local pid="$1"
  kill -0 "$pid" >/dev/null 2>&1
}

port_is_listening() {
  local port="$1"
  if command -v ss >/dev/null 2>&1; then
    ss -ltn 2>/dev/null | awk '{print $4}' | grep -q ":${port}$"
  elif command -v netstat >/dev/null 2>&1; then
    netstat -ltn 2>/dev/null | awk '{print $4}' | grep -q ":${port}$"
  else
    return 1
  fi
}

show_status() {
  local name="$1"
  local pid_file="$2"
  local port="$3"
  local has_pid_file="false"
  local pid_running="false"
  local port_listening="false"

  echo "$name:"
  if [[ -f "$pid_file" ]]; then
    has_pid_file="true"
    local pid
    pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && is_running "$pid"; then
      pid_running="true"
      echo "  process: running (pid $pid)"
    else
      echo "  process: not running (stale pid file)"
    fi
  else
    echo "  process: not running"
  fi

  if port_is_listening "$port"; then
    port_listening="true"
    echo "  port $port: listening"
  else
    echo "  port $port: not listening"
  fi

  if [[ "$port_listening" == "true" && "$pid_running" == "false" ]]; then
    if [[ "$has_pid_file" == "true" ]]; then
      echo "  note: service is listening but pid file is stale."
    else
      echo "  note: service is listening but was not started by ./start (or pid file missing)."
    fi
  fi
}

echo "==== SeeDance status ===="
show_status "backend" "$BACKEND_PID_FILE" 8000
echo ""
show_status "frontend" "$FRONTEND_PID_FILE" 5173
